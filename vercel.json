{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://inci-detective-api.merbeni.workers.dev/api/:path*"
    },
    {
      "source": "/share/:path*",
      "destination": "https://inci-detective-api.merbeni.workers.dev/share/:path*"
    },
    { "source": "/((?!assets/|.*\\..*).*)", "destination": "/index.html" }
  ]
}

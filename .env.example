# Copy to .env.local and fill with your Supabase project values.
# If left empty, the app runs fully offline/local (no cloud features) — this is
# intentional graceful degradation, the core app never requires a backend.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Only needed by scripts/seed-ingredients.mjs to upload the dataset to the cloud.
# NEVER expose the service-role key in the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=
